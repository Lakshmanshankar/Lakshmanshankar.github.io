---
import ProjectItems from "./project/project-cards.astro";
import ContactFooter from "./ui/ContactFooter.astro";
import WorkItems from "./work/work-cards.astro";
---

<div id="container">
    <article class="animate show">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
            <div>
                <h3 class="text-lg mb-2">👋 Hi, I'm</h3>
                <h2
                    class="font-bold bg-gradient-to-r from-red-500 to-pink-500 bg-clip-text text-transparent mb-4"
                >
                    Lakshmanshankar
                </h2>
                <h4>Software Engineer</h4>
                <p class="mt-2">Coimbatore - Chennai</p>
            </div>

            <div>
                <img
                    src="https://invk935vtx.ufs.sh/f/WLuidxolfrXgBf3Jo9QrpKQPOU5NyWRFZEd4HIiM3vXTuhqw"
                    alt="Lakshmanshankar"
                    class="max-w-md w-[250px] rounded-full h-[250px] object-cover object-[center_0px]"
                />
            </div>
        </div>

        <p>
            I'm a Software Engineer at
            <a href="https://bounteous.com" target="_blank"><strong>Bounteous</strong></a>, building
            features for an enterprise analytics platform. I work with <strong
                >PostgreSQL, Kafka</strong
            >, and semantic data layers, contributing to technical design, proof-of-concepts, and
            data-intensive workflows. I enjoy investigating data discrepancies and building reliable
            systems that turn complex requirements into useful products.
        </p>

        <p>
            Outside work, I build developer tools and content systems. My current project is
            <a href="https://builder-01.vercel.app" target="_blank">
                <strong>Pagewrite</strong>
            </a>, a content authoring platform focused on writing, reading, and publishing. It
            powers this website and includes a custom editor, typography controls, keyboard-first
            workflows, MDX publishing, and an Astro integration for static documentation sites.
        </p>

        <ul>
            <li>
                Contributed to
                <a href="https://github.com/facebook/lexical" target="_blank">
                    <strong>Lexical</strong>
                </a>
                and actively build open-source tooling.
            </li>

            <li>
                Interested in developer experience, databases, content infrastructure, editors, and
                knowledge-management systems.
            </li>

            <li>
                Linux user since 2022, GNOME enthusiast, and long-time Vim user. Check out my
                <a href="https://github.com/lakshmanshankar/dotfiles" target="_blank">
                    dotfiles
                </a>.
            </li>
            <li>
                Check out my resume <a
                    href="https://drive.google.com/file/d/1b66-OTVtubiZPjOIUConlT1IaHoTw3II/view?usp=sharing"
                    >here</a
                >
            </li>
        </ul>
    </article>

    <section id="projects" class="pt-5 transition-all px-4 md:px-10 full-width pb-10 rounded-md">
        <ProjectItems obeyCount={true} />
    </section>

    <section id="work" class="pt-5 transition-all px-4 md:px-10 full-width pb-10 rounded-md">
        <WorkItems obeyCount={true} />
    </section>
    <h3 class="mt-4 mb-7">Skills</h3>
    <section class="flex justify-between flex-col lg:flex-row">
        <div>
            <h4 class="mt-0 ml-8">Languages</h4>
            <ul>
                <li>Typescript</li>
                <li>Python</li>
                <li>Go</li>
            </ul>
        </div>

        <div>
            <h4 class="mt-0 ml-8">Frameworks & Tools</h4>
            <ul>
                <li>React, Next.js and Astro</li>
                <li>Cube</li>
                <li>Kafka</li>
                <li>Docker, Linux</li>
            </ul>
        </div>

        <div>
            <h4 class="mt-0 ml-8">Databases</h4>
            <ul>
                <li>Postgres</li>
                <li>Firestore</li>
            </ul>
        </div>
    </section>

    <section class="pt-5 mt-5 border-colors px-4 md:px-10 full-width pb-10">
        <h3>Contact</h3>
        <p>
            You can contact me directly @<a href="mailto:lakshmanshankarc@gmail.com"
                >lakshmanshankarc@gmail.com</a
            > or you can reach me on any of the following platforms:
        </p>
        <div class="text-white dark:text-white">
            <ContactFooter />
        </div>
    </section>
    <h3>Colophon</h3>
    <p>
        This Site is generated using astro(v5) with <a href="https://astro-nano.vercel.app"
            >Astro-nano</a
        >, and tailwindcss, All the code for this website is available <a
            href="https://github.com/Lakshmanshankar/lakshmanshankar.github.io">here</a
        > under <strong>`MIT License`</strong> and all the content is under creative commons license.
    </p>
    <hr />
</div>
