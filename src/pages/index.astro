---
import Home from "../components/home.astro";
import Layout from "../layouts/Layout.astro";

import { HOME, SOCIALS } from "@/consts";
import { Schema } from "astro-seo-schema";
const sameAsLinks = SOCIALS.map((s) => s.HREF);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
    <Fragment slot="head">
        <Schema
            item={{
                "@context": "https://schema.org",
                "@type": "Person",
                name: "Lakshmanshankar",
                alternateName: "Lakshman Shankar",
                description:
                    "I am a Software Engineer at Bounteous, working on a large-scale enterprise sales engagement platform with a focus on analytics.",
                alumniOf: [
                    {
                        "@type": "CollegeOrUniversity",
                        name: "Bharathiar University",
                        sameAs: "https://www.b-u.ac.in/",
                    },
                    {
                        "@type": "CollegeOrUniversity",
                        name: "KPR College of Arts and Science",
                        sameAs: "https://www.kprcas.ac.in/",
                    },
                ],
                knowsAbout: ["Full Stack Development", "Computer Science", "Cloud Computing"],
                sameAs: sameAsLinks,
            }}
        />
    </Fragment>
    <Home />
</Layout>
